<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>wonderlust</title>
</head>
<body>
    <h3>Create new listing</h3>
    <form method="POST" action="/listings">
        <input type="text" name="listing[title]" placeholder="Enter title">
        <br><br>
        <textarea name="listing[description]" id="" placeholder="Enter description"></textarea>
        <br><br>
        <input type="text" name="listing[image]" placeholder="Enter Image url">
        <br><br>
        <input type="number" name="listing[price]" placeholder="Enter number">
        <br><br>       
        <input type="text" name="listing[location]" placeholder="Enter location">
        <br><br>
        <input type="text" name="listing[country]" placeholder="Enter country">
        <br><br>
        <button>Add</button>
        <br>
    </form>
</body>
</html>