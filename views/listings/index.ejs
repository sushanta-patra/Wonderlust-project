<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>wonderlust</title>
</head>
<body>
    <h3>All listings data</h3>
    <form method="GET" action="/listing/new">
        <button>Create New Listing</button>
    </form>
    <ul>
    <% for(list of allListing){ %>
    <li><a href="listings/<%= list.id %>"><%= list.title %></a></li>
<% } %>
</ul>
</body>
</html>

