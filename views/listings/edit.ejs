<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wonderlust</title>
</head>
<body>
    <h3>Edit your listing</h3>
    <form method="POST" action="/listings/<%= list._id %>?_method=PUT">
        <input type="text" name="listing[title]" value="<%= list.title %>">
        <br><br>
        <textarea name="listing[description]" id=""><%= list.title %></textarea>
        <br><br>
        <input type="text" name="listing[image]" value="<%= list.image %>">
        <br><br>
        <input type="number" name="listing[price]" value="<%= list.price %>">
        <br><br>       
        <input type="text" name="listing[location]" value="<%= list.location %>">
        <br><br>
        <input type="text" name="listing[country]" value="<%= list.country %>">
        <br><br>
        <button>Update Edits</button>
        <br>
    </form>
</body>
</html>